{
  "services": {
    "frontend": {
      "root": "frontend",
      "framework": "nextjs"
    },
    "backend": {
      "root": "backend",
      "framework": "fastapi"
    }
  },
  "rewrites": [
    { "source": "/api/backend/(.*)", "destination": "/backend/$1" },
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ]
}
